programa {
  
  inteiro anoN
  inteiro result
  
  funcao inicio() {

    escreva("qual o seu ano de nascimento?: ")
    leia(anoN)

    result = 2026 - anoN

    se(result >= 18)
    escreva("\nAcesso Permitido ")

    senao
    escreva("\nAcesso Negado: Usuário menor de idade")





    

  
    
    




    
  }
}
