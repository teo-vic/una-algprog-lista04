programa {
  funcao inicio() {
    inteiro velocidade
    inteiro multa
    inteiro pag

    escreva("qual a velocidade?: ")
    leia(velocidade)

   multa = velocidade - 80

    pag = multa * 7
   
    se(velocidade <= 80){
       escreva("\nboa viagem")
    }

    senao 
    escreva("sua multa é de: ", pag, "R$")


    



    










    
  }
}
